{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bro",
  "version": "0.1.0",
  "identifier": "com.bro.code",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:frontend",
    "devUrl": "http://localhost:5314",
    "frontendDist": "../dist/app",
    "features": []
  },
  "app": {
    "windows": [
      {
        "title": "Bro",
        "width": 1375,
        "height": 938,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1000,
        "minHeight": 625,
        "transparent": false,
        "decorations": true,
        "backgroundColor": "#0d1117"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: tauri:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; img-src 'self' data: asset: https:; connect-src 'self' ipc: tauri: http: https: ws: wss:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": null
  }
}
